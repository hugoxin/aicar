{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage4.4 Optimized Machine Path Plan",
  "type": "object",
  "required": ["plan_version", "optimization_profile_id", "optimization_status", "safety_validation_status", "accepted_optimization", "baseline_summary", "optimized_summary", "improvement_summary", "trajectory_points", "optimized_segments", "transition_results", "removed_points", "rejected_candidates", "task_order_changes", "safety_validation", "warnings", "limitations"],
  "properties": {
    "plan_version": {"const": "stage4.4"},
    "optimization_profile_id": {"type": "string"},
    "optimization_status": {"enum": ["ACCEPTED", "ACCEPTED_WITH_WARNINGS", "NO_MEANINGFUL_IMPROVEMENT", "REJECTED_SAFETY_REGRESSION", "FAILED"]},
    "safety_validation_status": {"enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"]},
    "accepted_optimization": {"type": "boolean"},
    "baseline_summary": {"type": "object"},
    "optimized_summary": {"type": "object"},
    "improvement_summary": {"type": "object"},
    "trajectory_points": {"type": "array", "minItems": 1, "description": "Cartesian coordinates are in millimetres; timestamps are in seconds."},
    "optimized_segments": {"type": "array", "minItems": 1},
    "transition_results": {"type": "array"},
    "removed_points": {"type": "array"},
    "rejected_candidates": {"type": "array"},
    "task_order_changes": {"type": "array"},
    "safety_validation": {"type": "object"},
    "warnings": {"type": "array"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
