{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage4.5 Continuous Surface Safety Validation Report",
  "type": "object",
  "required": ["report_version", "reconstruction_status", "surface_validation_status", "motion_validation_status", "collision_validation_status", "summary", "motion_validation", "collision_validation", "schedule_validation", "warnings", "violations", "limitations"],
  "properties": {
    "report_version": {"const": "stage4.5"},
    "reconstruction_status": {"enum": ["ACCEPTED", "ACCEPTED_WITH_WARNINGS", "NO_MEANINGFUL_IMPROVEMENT", "REJECTED_SAFETY_REGRESSION", "FAILED"]},
    "surface_validation_status": {"enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"]},
    "motion_validation_status": {"enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"]},
    "collision_validation_status": {"enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"]},
    "summary": {"type": "object"},
    "motion_validation": {"type": "object"},
    "collision_validation": {"type": "object"},
    "schedule_validation": {"type": "object"},
    "warnings": {"type": "array"},
    "violations": {"type": "array"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
