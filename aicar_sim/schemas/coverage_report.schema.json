{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage2.6 Coverage Report",
  "type": "object",
  "required": [
    "report_version",
    "source_versions",
    "vehicle",
    "wash_profile",
    "wash_bay_id",
    "coverage_summary",
    "zone_reports",
    "warnings",
    "improvement_suggestions",
    "limitations"
  ],
  "properties": {
    "report_version": {
      "type": "string",
      "const": "stage2.6"
    },
    "source_versions": {
      "type": "object"
    },
    "vehicle": {
      "type": "object"
    },
    "wash_profile": {
      "type": "string"
    },
    "wash_bay_id": {
      "type": "string"
    },
    "coverage_summary": {
      "type": "object",
      "required": [
        "zone_count",
        "covered_zone_count",
        "uncovered_zone_count",
        "overall_target_coverage_percent",
        "estimated_actual_coverage_percent",
        "coverage_pass",
        "total_segment_count",
        "total_point_count",
        "notes"
      ]
    },
    "zone_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "zone_id",
          "target_coverage_percent",
          "estimated_coverage_percent",
          "coverage_pass",
          "segment_count",
          "point_count",
          "assigned_nozzles",
          "warnings"
        ]
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvement_suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
