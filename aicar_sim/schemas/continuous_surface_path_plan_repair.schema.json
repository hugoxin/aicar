{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "continuous_surface_path_plan_repair.schema.json",
  "title": "Stage4.5-R state-aware continuous surface path plan",
  "type": "object",
  "required": [
    "repair_version",
    "repair_profile_id",
    "surface_model_id",
    "summary",
    "states",
    "state_scan_policies",
    "surface_routes",
    "surface_tasks",
    "scan_passes",
    "connections",
    "trajectory_points",
    "coverage_summary",
    "path_length_breakdown",
    "aggregation_summary",
    "validation",
    "limitations"
  ],
  "properties": {
    "repair_version": {"const": "stage4.5-r"},
    "summary": {
      "type": "object",
      "required": ["state_count", "zone_count", "surface_patch_count", "wheel_patch_count", "scan_pass_count", "surface_task_count", "trajectory_point_count", "source_path_length_mm", "unique_geometric_coverage_percent"],
      "properties": {
        "source_path_length_mm": {"type": "number", "minimum": 0, "description": "Source nozzle path length in millimetres."},
        "unique_geometric_coverage_percent": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "states": {"type": "array", "minItems": 7},
    "state_scan_policies": {"type": "array", "items": {"$ref": "#/$defs/stateScanPolicy"}},
    "surface_routes": {"type": "array"},
    "surface_tasks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/surfaceTask"}},
    "scan_passes": {"type": "array", "minItems": 1},
    "connections": {"type": "array"},
    "trajectory_points": {"type": "array", "minItems": 1, "maxItems": 5000},
    "coverage_summary": {"type": "object", "required": ["unique_geometric_coverage_percent", "per_state_zone_coverage", "per_state_patch_coverage", "mean_surface_visit_count", "maximum_surface_visit_count", "overcovered_cell_percent", "repeated_surface_scan_length_mm", "coverage_efficiency_percent"]},
    "path_length_breakdown": {"type": "object", "description": "Path lengths are expressed in millimetres."},
    "aggregation_summary": {"type": "object", "required": ["validation_status", "source_scan_pass_count", "aggregated_surface_task_count"]},
    "validation": {"type": "object", "required": ["validation_status", "violation_count"]},
    "limitations": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "stateScanPolicy": {
      "type": "object",
      "required": ["state_id", "zone_id", "patch_id", "nozzle_id", "effective_width_mm", "effective_width_source", "initial_pass_spacing_mm", "final_pass_spacing_mm", "coverage_percent"]
    },
    "surfaceTask": {
      "type": "object",
      "required": ["surface_task_id", "state_id", "surface_route_id", "actuator_id", "nozzle_id", "patch_ids", "scan_pass_ids", "estimated_duration_s"]
    }
  }
}
